 Find Pivot Index


class Solution {
    public int pivotIndex(int[] nums) {
        int totalSum = 0;
        
        // Calculate total sum of array
        for (int num : nums) {
            totalSum += num;
        }
        
        int leftSum = 0;
        
        // Iterate through each index as potential pivot
        for (int i = 0; i < nums.length; i++) {
            // Right sum = totalSum - leftSum - nums[i]
            if (leftSum == totalSum - leftSum - nums[i]) {
                return i;
            }
            leftSum += nums[i];
        }
        
        return -1;
    }
}
