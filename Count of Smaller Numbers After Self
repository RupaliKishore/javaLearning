  Count of Smaller Numbers After Self

import java.util.*;

class Solution {
    public List<Integer> countSmaller(int[] nums) {
        int n = nums.length;
        int[] result = new int[n];
        int[] indices = new int[n]; // Store original indices
        
        // Initialize indices
        for (int i = 0; i < n; i++) {
            indices[i] = i;
        }
        
        // Merge sort while counting
        mergeSort(nums, indices, result, 0, n - 1);
        
        // Convert to List
        List<Integer> resultList = new ArrayList<>();
        for (int count : result) {
            resultList.add(count);
        }
        return resultList;
    }
    
    private void mergeSort(int[] nums, int[] indices, int[] result, int left, int right) {
        if (left >= right) return;
        
        int mid = left + (right - left) / 2;
        mergeSort(nums, indices, result, left, mid);
        mergeSort(nums, indices, result, mid + 1, right);
        merge(nums, indices, result, left, mid, right);
    }
    
    private void merge(int[] nums, int[] indices, int[] result, int left, int mid, int right) {
        int[] tempIndices = new int[right - left + 1];
        int i = left;     // Pointer for left half
        int j = mid + 1;  // Pointer for right half
        int k = 0;        // Pointer for temp array
        int rightCount = 0; // Count of smaller elements from right half
        
        while (i <= mid && j <= right) {
            if (nums[indices[i]] <= nums[indices[j]]) {
                // Element from left half: all elements in right half processed so far are smaller
                result[indices[i]] += rightCount;
                tempIndices[k++] = indices[i++];
            } else {
                // Element from right half: it's smaller than current left element
                rightCount++;
                tempIndices[k++] = indices[j++];
            }
        }
        
        // Process remaining left elements
        while (i <= mid) {
            result[indices[i]] += rightCount;
            tempIndices[k++] = indices[i++];
        }
        
        // Process remaining right elements
        while (j <= right) {
            tempIndices[k++] = indices[j++];
        }
        
        // Copy back to indices array
        System.arraycopy(tempIndices, 0, indices, left, tempIndices.length);
    }
}
