  Same Tree


  class TreeNode {
    int val;
    TreeNode left;
    TreeNode right;
    
    TreeNode() {}
    TreeNode(int val) { this.val = val; }
    TreeNode(int val, TreeNode left, TreeNode right) {
        this.val = val;
        this.left = left;
        this.right = right;
    }
}

class Solution {
    public boolean isSameTree(TreeNode p, TreeNode q) {
        // Both null -> same
        if (p == null && q == null) {
            return true;
        }
        
        // One null, other not -> different
        if (p == null || q == null) {
            return false;
        }
        
        // Values must be equal and subtrees must be same
        return p.val == q.val 
            && isSameTree(p.left, q.left)
            && isSameTree(p.right, q.right);
    }
}
