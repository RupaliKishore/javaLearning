  Best Time to Buy and Sell Stock with Cooldown

class Solution {
    public int maxProfit(int[] prices) {
        if (prices == null || prices.length <= 1) {
            return 0;
        }
        
        int n = prices.length;
        
        // State definitions
        int hold = -prices[0];     // Max profit when holding stock
        int sold = 0;               // Max profit just after selling
        int cooldown = 0;           // Max profit in cooldown period
        
        for (int i = 1; i < n; i++) {
            int prevHold = hold;
            int prevSold = sold;
            int prevCooldown = cooldown;
            
            // Can only buy from cooldown state
            hold = Math.max(prevHold, prevCooldown - prices[i]);
            
            // Can only sell from hold state
            sold = prevHold + prices[i];
            
            // Cooldown can come from sold or stay in cooldown
            cooldown = Math.max(prevCooldown, prevSold);
        }
        
        return Math.max(sold, cooldown);
    }
}
