 Sort Colors

class Solution {
    public void sortColors(int[] nums) {
        int low = 0;      // Boundary for 0s
        int mid = 0;      // Current element pointer
        int high = nums.length - 1;  // Boundary for 2s
        
        while (mid <= high) {
            if (nums[mid] == 0) {
                // Swap with low boundary
                swap(nums, low, mid);
                low++;
                mid++;
            } else if (nums[mid] == 1) {
                // 1 is in correct position
                mid++;
            } else { // nums[mid] == 2
                // Swap with high boundary
                swap(nums, mid, high);
                high--;
                // Don't increment mid because swapped element needs checking
            }
        }
    }
    
    private void swap(int[] nums, int i, int j) {
        int temp = nums[i];
        nums[i] = nums[j];
        nums[j] = temp;
    }
}
