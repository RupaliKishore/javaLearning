Dota2 Senate


import java.util.*;

class Solution {
    public String predictPartyVictory(String senate) {
        Queue<Integer> radiant = new LinkedList<>();
        Queue<Integer> dire = new LinkedList<>();
        
        int n = senate.length();
        
        // Record the indices of each party's senators
        for (int i = 0; i < n; i++) {
            if (senate.charAt(i) == 'R') {
                radiant.offer(i);
            } else {
                dire.offer(i);
            }
        }
        
        // Simulate the banning process
        while (!radiant.isEmpty() && !dire.isEmpty()) {
            int rIndex = radiant.poll();
            int dIndex = dire.poll();
            
            // The senator with smaller index gets to ban first
            if (rIndex < dIndex) {
                // Radiant bans this Dire senator
                // This Radiant senator will vote again in the next round
                radiant.offer(rIndex + n);
            } else {
                // Dire bans this Radiant senator
                // This Dire senator will vote again in the next round
                dire.offer(dIndex + n);
            }
        }
        
        return radiant.isEmpty() ? "Dire" : "Radiant";
    }
}
