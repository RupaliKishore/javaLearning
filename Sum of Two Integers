Sum of Two Integers


class Solution {
    public int getSum(int a, int b) {
        while (b != 0) {
            // Calculate carry (bits where both a and b have 1)
            int carry = (a & b) << 1;
            
            // Calculate sum without carry (XOR)
            a = a ^ b;
            
            // Assign carry to b for next iteration
            b = carry;
        }
        
        return a;
    }
}
