Count and Say

class Solution {
    public String countAndSay(int n) {
        String result = "1";
        
        for (int i = 2; i <= n; i++) {
            // Split into groups of same characters
            String[] groups = result.split("(?<=(.))(?!\\1)");
            StringBuilder sb = new StringBuilder();
            
            for (String group : groups) {
                sb.append(group.length());
                sb.append(group.charAt(0));
            }
            
            result = sb.toString();
        }
        
        return result;
    }
}
