 Construct Binary Tree from Inorder and Postorder Traversal


 class TreeNode {
    int val;
    TreeNode left;
    TreeNode right;
    
    TreeNode() {}
    TreeNode(int val) { this.val = val; }
    TreeNode(int val, TreeNode left, TreeNode right) {
        this.val = val;
        this.left = left;
        this.right = right;
    }
}

class Solution {
    public TreeNode buildTree(int[] inorder, int[] postorder) {
        if (inorder == null || postorder == null || inorder.length != postorder.length) {
            return null;
        }
        
        // Create a map for O(1) lookup of inorder indices
        Map<Integer, Integer> inorderMap = new HashMap<>();
        for (int i = 0; i < inorder.length; i++) {
            inorderMap.put(inorder[i], i);
        }
        
        return buildTreeHelper(inorder, 0, inorder.length - 1,
                               postorder, 0, postorder.length - 1,
                               inorderMap);
    }
    
    private TreeNode buildTreeHelper(int[] inorder, int inStart, int inEnd,
                                     int[] postorder, int postStart, int postEnd,
                                     Map<Integer, Integer> inorderMap) {
        // Base case: no elements to process
        if (inStart > inEnd || postStart > postEnd) {
            return null;
        }
        
        // Root is the last element in postorder
        int rootVal = postorder[postEnd];
        TreeNode root = new TreeNode(rootVal);
        
        // Find root's index in inorder
        int rootIndex = inorderMap.get(rootVal);
        int leftSubtreeSize = rootIndex - inStart;
        
        // Recursively build left and right subtrees
        root.left = buildTreeHelper(inorder, inStart, rootIndex - 1,
                                   postorder, postStart, postStart + leftSubtreeSize - 1,
                                   inorderMap);
        
        root.right = buildTreeHelper(inorder, rootIndex + 1, inEnd,
                                    postorder, postStart + leftSubtreeSize, postEnd - 1,
                                    inorderMap);
        
        return root;
    }
}
